    {
      "name": "Signature",
      "item": [
        {
          "name": "Create Account",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corp Signing Account\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/signature/accounts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "signature", "accounts"]
            },
            "description": "Create a signing account that groups signers, groups, and rules."
          },
          "response": []
        },
        {
          "name": "Create Faculty",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"APPROVE_CONTRACT\",\n  \"name\": \"Approve Contract\",\n  \"description\": \"Faculty to approve contracts up to $100,000 USD\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/signature/faculties",
              "host": ["{{baseUrl}}"],
              "path": ["api", "signature", "faculties"]
            },
            "description": "Create a faculty (permission type) that defines what is being authorized when signatures are collected."
          },
          "response": []
        },
        {
          "name": "Create Group",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountId\": \"ACCOUNT_UUID_HERE\",\n  \"name\": \"Board of Directors\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/signature/groups",
              "host": ["{{baseUrl}}"],
              "path": ["api", "signature", "groups"]
            },
            "description": "Create a signer group within an account."
          },
          "response": []
        },
        {
          "name": "Create Rule",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountId\": \"ACCOUNT_UUID_HERE\",\n  \"facultyId\": \"FACULTY_UUID_HERE\",\n  \"ruleLogic\": {\n    \"combinations\": [\n      { \"groupId\": \"GROUP_A_UUID\", \"minSigners\": 2 },\n      { \"groupId\": \"GROUP_B_UUID\", \"minSigners\": 1 }\n    ],\n    \"operator\": \"OR\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/signature/rules",
              "host": ["{{baseUrl}}"],
              "path": ["api", "signature", "rules"]
            },
            "description": "Define a signing rule linking an account, a faculty, and the required combination of group signatures."
          },
          "response": []
        },
        {
          "name": "Create Signature Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountId\": \"ACCOUNT_UUID_HERE\",\n  \"facultyId\": \"FACULTY_UUID_HERE\",\n  \"documentName\": \"Service Agreement Q1 2026\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/signature/requests",
              "host": ["{{baseUrl}}"],
              "path": ["api", "signature", "requests"]
            },
            "description": "Create a new signature request for a document. The system will resolve the required combinations from the rule associated with the faculty."
          },
          "response": []
        },
        {
          "name": "Sign Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"signerId\": \"SIGNER_UUID_HERE\",\n  \"groupId\": \"GROUP_UUID_HERE\",\n  \"signatureData\": \"base64-encoded-signature-or-token\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/signature/requests/:id/sign",
              "host": ["{{baseUrl}}"],
              "path": ["api", "signature", "requests", ":id", "sign"],
              "variable": [
                {
                  "key": "id",
                  "value": "SIGNATURE_REQUEST_UUID_HERE"
                }
              ]
            },
            "description": "Submit a signature for an existing signature request. Once all required combinations are satisfied, the request status moves to COMPLETED."
          },
          "response": []
        }
      ]
    },
